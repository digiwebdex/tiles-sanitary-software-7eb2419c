# Database
DATABASE_URL=postgres://tileserp:CHANGE_ME@db:5432/tileserp

# JWT
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_RANDOM_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
# NOTE: production VPS runs this backend via PM2 on port 3003.
PORT=3003
NODE_ENV=production
# Comma-separated list of every public origin allowed to call the API.
CORS_ORIGIN=https://sanitileserp.com,https://www.sanitileserp.com,https://app.sanitileserp.com,https://portal.sanitileserp.com

# SMTP (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SMS (BulkSMSBD)
BULKSMSBD_API_KEY=
BULKSMSBD_API_URL=http://bulksmsbd.net/api/smsapi
BULKSMSBD_SENDER_ID=
