# Supabase Configuration (managed by Lovable Cloud)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# NOTE: DATABASE_URL, JWT_SECRET, and other server-side secrets
# are managed automatically by Lovable Cloud and should NOT be
# added here. They are configured in the backend environment.

# ─── VPS Migration toggles ─────────────────────────────────────────────
# Phase 1 — auth backend (default: supabase). Flip to "vps" only after
# VpsAuthContext is mounted in App.tsx.
# VITE_AUTH_BACKEND=supabase

# Phase 2/3 — per-resource data backend. Each accepts:
#   supabase | shadow | vps
# Default for every resource is supabase (no behavior change).
#
# Phase 3B active rollout — Suppliers shadow mode:
# VITE_DATA_SUPPLIERS=shadow
#
# Other resources MUST stay on supabase until their own phase begins.
# VITE_DATA_CUSTOMERS=supabase
# VITE_DATA_PRODUCTS=supabase
# VITE_DATA_SALES=supabase
# VITE_DATA_QUOTATIONS=supabase
# VITE_DATA_DELIVERIES=supabase
# VITE_DATA_PURCHASES=supabase

# Self-hosted backend base URL (used by vpsAdapter + authBridge)
# VITE_VPS_API_BASE=https://api.sanitileserp.com
